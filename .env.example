# Root environment configuration for HUSTLERS monorepo

# Backend
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hustlers?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=replace_with_secure_secret
REFRESH_TOKEN_SECRET=replace_with_secure_refresh_secret

# IntaSend / M-Pesa
INTASEND_API_KEY=replace_with_intasend_api_key
INTASEND_BASE_URL=https://sandbox.intasend.com
INTASEND_CALLBACK_URL=https://yourapp.com/api/payments/callback

# Mobile/app settings
REACT_APP_API_BASE_URL=https://api.hustlers.app
EXPO_PUBLIC_API_BASE_URL=https://api.hustlers.app
