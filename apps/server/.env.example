# ===== ENVIRONMENT CONFIGURATION =====
# Copy this file to .env and fill in your actual values

# ===== SERVER CONFIGURATION =====
PORT=5000
NODE_ENV=development
API_VERSION=v1
API_PREFIX=/api

# ===== DATABASE CONFIGURATION =====
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/hustlers

# ===== AUTHENTICATION =====
# JWT Secret keys (generate strong random strings in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production-at-least-32-chars

# JWT Token expiration times
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ===== CORS CONFIGURATION =====
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ===== EMAIL CONFIGURATION (Optional) =====
# Used for email notifications, password resets, etc.
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# ===== LOGGING =====
LOG_LEVEL=info

# ===== RATE LIMITING =====
# In production, consider using Redis for distributed rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===== SECURITY =====
# Set to 'true' to enforce HTTPS in production
ENFORCE_HTTPS=false

# ===== REDIS CONFIGURATION (Optional) =====
# For caching, rate limiting, and session management in production
REDIS_URL=redis://localhost:6379

# ===== THIRD-PARTY SERVICES =====
# AWS S3 for file uploads
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ===== MONITORING & OBSERVABILITY =====
# Sentry for error tracking
SENTRY_DSN=

# New Relic for APM
NEW_RELIC_LICENSE_KEY=

# ===== FEATURE FLAGS =====
# Enable/disable features for testing
FEATURE_TWO_FACTOR_AUTH=false
FEATURE_OAUTH=false
FEATURE_SOCIAL_LOGIN=false
